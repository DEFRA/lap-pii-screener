<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sensitive Code Scan — {{ report.project_name }}</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         background: #0f1117; color: #e2e8f0; line-height: 1.6; }
  a { color: #93c5fd; }
  a:focus-visible { outline: 3px solid #93c5fd; outline-offset: 2px; border-radius: 2px; }

  /* Skip navigation link — visible on focus only */
  .skip-link { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; }
  .skip-link:focus { position: fixed; top: 1rem; left: 1rem; width: auto; height: auto;
                     padding: .5rem 1rem; background: #1a202c; color: #e2e8f0;
                     border: 2px solid #93c5fd; border-radius: 4px; z-index: 9999;
                     font-size: 1rem; text-decoration: none; outline: 3px solid #93c5fd; }

  .header { background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
            padding: 2rem; border-bottom: 1px solid #4a5568; }
  .header h1 { font-size: 1.75rem; font-weight: 700; color: #f7fafc; }
  .header .meta { margin-top: .75rem; display: flex; flex-wrap: wrap; gap: .5rem 1.75rem;
                   font-size: .8rem; }
  .header .meta-item { display: flex; flex-direction: column; gap: .1rem; }
  .header .meta-label { color: #718096; font-size: .65rem; text-transform: uppercase;
                        letter-spacing: .08em; font-weight: 600; }
  .header .meta-value { color: #cbd5e0; }

  /* Summary stat cards */
  .summary { display: flex; gap: 1rem; padding: 1.5rem 2rem; flex-wrap: wrap; }
  .summary.summary-meta { padding-top: 0; }
  .card { flex: 1; min-width: 120px; border-radius: 8px; padding: 1rem 1.25rem;
          text-align: center; border: 2px solid; }
  .card .count { font-size: 2rem; font-weight: 800; }
  .card .label { font-size: .75rem; text-transform: uppercase; letter-spacing: .08em;
                 color: #cbd5e0; }
  .card.critical { background: #2d1515; border-color: #fc8181; }
  .card.critical .count { color: #fc8181; }
  .card.high    { background: #2d1f0a; border-color: #f6ad55; }
  .card.high    .count { color: #f6ad55; }
  .card.medium  { background: #2d2a0a; border-color: #f6e05e; }
  .card.medium  .count { color: #f6e05e; }
  .card.low     { background: #0a2030; border-color: #63b3ed; }
  .card.low     .count { color: #93c5fd; }
  .card.total   { background: #1a202c; border-color: #718096; }
  .card.total   .count { color: #e2e8f0; }
  .card.files   { background: #112218; border-color: #68d391; }
  .card.files   .count { color: #68d391; }
  .card.skipped { background: #1a1a2e; border-color: #718096; }
  .card.skipped .count { color: #a0aec0; }
  .card.lines   { background: #0f1c2e; border-color: #76e4f7; }
  .card.lines   .count { color: #76e4f7; }
  .card.lines-skipped { background: #1a1a2e; border-color: #718096; }
  .card.lines-skipped .count { color: #a0aec0; }

  /* Collapsible severity section headers — styled as buttons */
  .section { padding: 0 2rem 2rem; }
  .section-header { cursor: pointer; display: flex; align-items: center; gap: .5rem;
                    padding: .75rem 1rem; border-radius: 6px; margin-bottom: .5rem;
                    font-weight: 600; font-size: 1rem; user-select: none;
                    border: 2px solid transparent; background: none; width: 100%;
                    text-align: left; }
  .section-header:hover { opacity: .85; }
  .section-header:focus-visible { outline: 3px solid #93c5fd; outline-offset: 2px; }
  .section-header.critical { background: #2d1515; color: #fc8181; border-color: #fc8181; }
  .section-header.high     { background: #2d1f0a; color: #f6ad55; border-color: #f6ad55; }
  .section-header.medium   { background: #2d2a0a; color: #f6e05e; border-color: #f6e05e; }
  .section-header.low      { background: #0a2030; color: #93c5fd; border-color: #63b3ed; }
  .section-header.info     { background: #1a202c; color: #cbd5e0; border-color: #718096; }
  .section-header .arrow   { transition: transform .2s; display: inline-block; }
  .section-header[aria-expanded="false"] .arrow { transform: rotate(-90deg); }

  table { width: 100%; border-collapse: collapse; font-size: .825rem; margin-bottom: 1rem; }
  thead tr { background: #1e2533; }
  th { text-align: left; padding: .5rem .75rem; color: #cbd5e0; font-weight: 600;
       border-bottom: 2px solid #4a5568; }
  tbody tr { border-bottom: 1px solid #1a2030; transition: background .1s; }
  tbody tr:hover { background: #1e2533; }
  td { padding: .5rem .75rem; vertical-align: top; }

  .badge { display: inline-block; padding: .1rem .5rem; border-radius: 4px;
           font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .badge.critical { background: #9b2c2c; color: #fff; }
  .badge.high     { background: #c05621; color: #fff; }
  .badge.medium   { background: #975a16; color: #fff; }
  .badge.low      { background: #2b6cb0; color: #fff; }
  .badge.info     { background: #4a5568; color: #e2e8f0; }

  /* Confidence score pill badges (only shown when show_confidence=True) */
  .conf-badge { display: inline-block; padding: .1rem .45rem; border-radius: 999px;
                font-size: .65rem; font-weight: 700; letter-spacing: .04em; font-variant-numeric: tabular-nums; }
  .conf-high  { background: #276749; color: #9ae6b4; }
  .conf-med   { background: #7b4a0a; color: #fbd38d; }
  .conf-low   { background: #9b2c2c; color: #fed7d7; }

  /* Regulation pill badges */
  .reg-badge { display: inline-block; padding: .15rem .45rem; border-radius: 4px;
               font-size: .65rem; font-weight: 700; letter-spacing: .05em;
               margin: .1rem .1rem .1rem 0; white-space: nowrap; }
  .reg-badge.UK-GDPR-PD  { background: #1a3a5c; color: #93c5fd; border: 1px solid #4299e1; }
  .reg-badge.UK-GDPR-SC  { background: #3b1f5c; color: #d6bcfa; border: 1px solid #805ad5; }
  .reg-badge.UK-GDPR-51F { background: #3b2a10; color: #fbd38d; border: 1px solid #c05621; }
  .reg-badge.PSR-2017    { background: #1c3829; color: #9ae6b4; border: 1px solid #38a169; }

  /* Regulation summary bar */
  .reg-summary { padding: .75rem 2rem 1.25rem; }
  .reg-summary h2 { font-size: .85rem; color: #cbd5e0; text-transform: uppercase;
                    letter-spacing: .08em; margin-bottom: .75rem; font-weight: 600; }
  .reg-cards { display: flex; gap: .75rem; flex-wrap: wrap; }
  .reg-card { border-radius: 6px; padding: .6rem 1rem; border: 2px solid #4a5568;
              background: #1a202c; min-width: 160px; }
  .reg-card.UK-GDPR-PD { border-color: #4299e1; background: #111d2e; }
  .reg-card.UK-GDPR-SC { border-color: #805ad5; background: #1e1230; }
  .reg-card.UK-GDPR-51F{ border-color: #c05621; background: #1f1508; }
  .reg-card.PSR-2017   { border-color: #38a169; background: #0d1f16; }
  .reg-card .reg-count { font-size: 1.75rem; font-weight: 800; line-height: 1; }
  .reg-card .reg-count-label { font-size: .7rem; color: #a0aec0; margin-bottom: .6rem; }
  .reg-card .reg-article-num { font-size: .95rem; font-weight: 700; margin-bottom: .15rem; }
  .reg-card .reg-full-name { font-size: .7rem; color: #cbd5e0; margin-bottom: .5rem; }
  .reg-card .reg-id-pill { font-size: .6rem; }
  .reg-card.UK-GDPR-PD .reg-id, .reg-card.UK-GDPR-PD .reg-count, .reg-card.UK-GDPR-PD .reg-article-num { color: #93c5fd; }
  .reg-card.UK-GDPR-SC .reg-id, .reg-card.UK-GDPR-SC .reg-count, .reg-card.UK-GDPR-SC .reg-article-num { color: #d6bcfa; }
  .reg-card.UK-GDPR-51F .reg-id, .reg-card.UK-GDPR-51F .reg-count, .reg-card.UK-GDPR-51F .reg-article-num { color: #fbd38d; }
  .reg-card.PSR-2017   .reg-id, .reg-card.PSR-2017   .reg-count, .reg-card.PSR-2017   .reg-article-num { color: #9ae6b4; }

  code { background: #1a2030; padding: .1rem .35rem; border-radius: 3px;
         font-family: "Fira Code", "Cascadia Code", monospace; font-size: .8rem; color: #e2e8f0; }

  .remediation { background: #111827; border: 1px solid #4a5568; border-radius: 6px;
                 padding: 1rem; margin-top: .25rem; font-size: .8rem; }
  .remediation ol { padding-left: 1.25rem; margin-top: .5rem; }
  .remediation li { margin-bottom: .25rem; }
  .remediation .refs { margin-top: .5rem; color: #cbd5e0; }

  details summary { cursor: pointer; }
  details summary:focus-visible { outline: 3px solid #93c5fd; outline-offset: 2px; border-radius: 2px; }
  details > div { padding: .5rem 0; }

  .empty { color: #68d391; font-size: 1.1rem; padding: 2rem;
           text-align: center; border: 2px dashed #38a169; border-radius: 8px; margin: 2rem; }

  /* Visually hidden utility for screen-reader-only text */
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
             overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  /* Obfuscation status badges */
  .obf-badge { display: inline-block; padding: .15rem .5rem; border-radius: 4px;
               font-size: .7rem; font-weight: 700; letter-spacing: .05em; white-space: nowrap; }
  .obf-approved { background: #0d2e1a; color: #68d391; border: 1px solid #38a169; }
  .obf-skipped  { background: #1a1a2e; color: #a0aec0; border: 1px solid #4a5568; }
  .obf-manual   { background: #2d1f0a; color: #f6ad55; border: 1px solid #c05621; }
  .obf-pending  { background: #1e2533; color: #718096; border: 1px solid #4a5568; }
  .obf-reason   { display: block; font-size: .65rem; color: #a0aec0; margin-top: .2rem;
                  font-style: italic; max-width: 180px; white-space: normal; }
  .card.obfuscated { background: #0d2e1a; border-color: #38a169; }
  .card.obfuscated .count { color: #68d391; }

  /* Dry-run banner */
  .dry-run-banner { background: #2d2000; border: 3px solid #f6ad55;
                    border-radius: 8px; margin: 1.5rem 2rem;
                    padding: 1rem 1.5rem; display: flex; align-items: center;
                    gap: 1rem; }
  .dry-run-banner .dry-run-icon { font-size: 2rem; flex-shrink: 0; }
  .dry-run-banner h2 { color: #f6ad55; font-size: 1.1rem; font-weight: 700;
                       margin-bottom: .25rem; }
  .dry-run-banner p  { color: #fbd38d; font-size: .85rem; margin: 0; }
</style>
</head>
<body>

<a class="skip-link" href="#main-content">Skip to main content</a>

<header class="header" role="banner">
  <h1>Sensitive Code Scan Report</h1>
  <dl class="meta" aria-label="Scan metadata">
    <div class="meta-item">
      <dt class="meta-label">Project</dt>
      <dd class="meta-value"><strong>{{ report.project_name }}</strong></dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Path</dt>
      <dd class="meta-value">{{ report.target_path }}</dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Scanned at</dt>
      <dd class="meta-value"><time datetime="{{ report.scanned_at.strftime('%Y-%m-%dT%H:%M') }}">{{ report.scanned_at.strftime('%Y-%m-%d %H:%M UTC') }}</time></dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Scanners</dt>
      <dd class="meta-value">{{ report.scanners_run | join(', ') }}</dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Duration</dt>
      <dd class="meta-value">{{ report.duration_seconds }}s
        {% if report.scanner_durations %}
        <span style="font-size:0.85em;color:#6b7280;margin-left:0.5em;">
          ({% for name, secs in report.scanner_durations.items() %}{{ name }}: {{ secs }}s{% if not loop.last %}, {% endif %}{% endfor %})
        </span>
        {% endif %}
      </dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Tier</dt>
      <dd class="meta-value">{{ report.tier_used }}</dd>
    </div>
    <div class="meta-item">
      <dt class="meta-label">Scan ID</dt>
      <dd class="meta-value">{{ report.scan_id }}</dd>
    </div>
  </dl>
</header>

<main id="main-content">

{% if dry_run %}
<div class="dry-run-banner" role="alert" aria-live="assertive">
  <div class="dry-run-icon" aria-hidden="true">&#9888;</div>
  <div>
    <h2>DRY RUN — No files were modified</h2>
    <p>This report shows what <em>would</em> have been obfuscated. Re-run without
       <code>--dry-run</code> to apply changes and produce a live report.</p>
  </div>
</div>
{% endif %}

<section aria-label="Severity summary">
  <div class="summary" role="list">
    <div class="card critical" role="listitem"><div class="count" aria-label="{{ report.summary.critical }} critical findings">{{ report.summary.critical }}</div><div class="label" aria-hidden="true">Critical</div></div>
    <div class="card high"     role="listitem"><div class="count" aria-label="{{ report.summary.high }} high findings">{{ report.summary.high }}</div>         <div class="label" aria-hidden="true">High</div></div>
    <div class="card medium"   role="listitem"><div class="count" aria-label="{{ report.summary.medium }} medium findings">{{ report.summary.medium }}</div>   <div class="label" aria-hidden="true">Medium</div></div>
    <div class="card low"      role="listitem"><div class="count" aria-label="{{ report.summary.low }} low findings">{{ report.summary.low }}</div>            <div class="label" aria-hidden="true">Low</div></div>
    <div class="card total"    role="listitem"><div class="count" aria-label="{{ report.summary.total }} total findings">{{ report.summary.total }}</div>      <div class="label" aria-hidden="true">Total Findings</div></div>
  </div>
  <div class="summary summary-meta" role="list">
    <div class="card files"   role="listitem"><div class="count" aria-label="{{ report.summary.files_scanned }} files scanned">{{ report.summary.files_scanned }}</div><div class="label" aria-hidden="true">Files Scanned</div></div>
    <div class="card skipped" role="listitem"><div class="count" aria-label="{{ report.summary.files_skipped }} files skipped">{{ report.summary.files_skipped }}</div><div class="label" aria-hidden="true">Files Skipped</div></div>
    <div class="card lines"   role="listitem"><div class="count" aria-label="{{ '{:,}'.format(report.summary.lines_scanned) }} lines scanned">{{ "{:,}".format(report.summary.lines_scanned) }}</div><div class="label" aria-hidden="true">Lines Scanned</div></div>
    {% if report.summary.lines_skipped %}<div class="card lines-skipped" role="listitem"><div class="count" aria-label="{{ '{:,}'.format(report.summary.lines_skipped) }} lines skipped">{{ "{:,}".format(report.summary.lines_skipped) }}</div><div class="label" aria-hidden="true">Lines Skipped</div></div>{% endif %}
  </div>
  {% if obfuscation_items %}
  {% set obf_approved_count = obfuscation_items.values() | selectattr('decision', 'equalto', 'approved') | list | length %}
  {% set obf_skipped_count  = obfuscation_items.values() | selectattr('decision', 'equalto', 'skipped')  | list | length %}
  {% set obf_manual_count   = obfuscation_items.values() | selectattr('decision', 'equalto', 'manual')   | list | length %}
  {% if obf_approved_count > 0 or obf_skipped_count > 0 or obf_manual_count > 0 %}
  <div class="summary summary-meta" role="list" aria-label="Obfuscation summary">
    {% if obf_approved_count > 0 %}
    <div class="card obfuscated" role="listitem"><div class="count" aria-label="{{ obf_approved_count }} obfuscations applied">{{ obf_approved_count }}</div><div class="label" aria-hidden="true">Obfuscations Applied</div></div>
    {% endif %}
    {% if obf_skipped_count > 0 %}
    <div class="card skipped" role="listitem"><div class="count" aria-label="{{ obf_skipped_count }} findings skipped">{{ obf_skipped_count }}</div><div class="label" aria-hidden="true">Skipped (Reviewed)</div></div>
    {% endif %}
    {% if obf_manual_count > 0 %}
    <div class="card high" role="listitem"><div class="count" aria-label="{{ obf_manual_count }} findings need manual remediation">{{ obf_manual_count }}</div><div class="label" aria-hidden="true">Manual Remediation</div></div>
    {% endif %}
  </div>
  {% endif %}
  {% endif %}
  {% if show_confidence %}
  {% set low_conf_count = report.findings | selectattr('confidence', 'lt', 0.65) | list | length %}
  {% if low_conf_count > 0 %}
  <div class="summary summary-meta" role="list" aria-label="Confidence summary">
    <div class="card high" role="listitem"><div class="count" aria-label="{{ low_conf_count }} low-confidence findings">{{ low_conf_count }}</div><div class="label" aria-hidden="true">Low Confidence</div></div>
  </div>
  {% endif %}
  {% endif %}
</section>

{% set reg_ids = [] %}
{% for f in report.findings %}{% for r in f.regulations %}{% if r not in reg_ids %}{% set _ = reg_ids.append(r) %}{% endif %}{% endfor %}{% endfor %}
{% if reg_ids | sort %}
<section class="reg-summary" aria-label="Applicable regulations">
  <h2>Applicable Regulations</h2>
  <div class="reg-cards" role="list">
    {% for reg_id in reg_ids | sort %}
    {% set ns = namespace(count=0) %}
    {% for f in report.findings %}{% if reg_id in f.regulations %}{% set ns.count = ns.count + 1 %}{% endif %}{% endfor %}
    {% set meta = regulations_meta.get(reg_id, {}) %}
    <div class="reg-card {{ reg_id }}" role="listitem"
         aria-label="{{ meta.get('name') or reg_id }}: {{ ns.count }} finding{{ 's' if ns.count != 1 else '' }}">
      <div class="reg-count" aria-hidden="true">{{ ns.count }}</div>
      <div class="reg-count-label" aria-hidden="true">finding{{ 's' if ns.count != 1 else '' }}</div>
      <div class="reg-article-num">{{ meta.get('article') or reg_id }}</div>
      <div class="reg-full-name">{{ meta.get('name') or reg_id }}</div>
      <span class="reg-id-pill reg-badge {{ reg_id }}" aria-hidden="true">{{ reg_id }}</span>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if not report.findings %}
<p class="empty" role="status">No sensitive findings detected — codebase looks clean!</p>
{% else %}

{% set severities = ['critical', 'high', 'medium', 'low', 'info'] %}
{% for sev in severities %}
  {% set sev_findings = report.findings | selectattr('severity', 'equalto', sev) | list %}
  {% if sev_findings %}
  <section class="section" aria-label="{{ sev | upper }} severity findings">
    <button class="section-header {{ sev }}" aria-expanded="true"
            aria-controls="section-body-{{ sev }}"
            onclick="toggle(this)">
      <span class="arrow" aria-hidden="true">&#9660;</span>
      <span>{{ sev | upper }} — {{ sev_findings | length }} finding{{ 's' if sev_findings | length != 1 else '' }}</span>
    </button>
    <div class="section-body" id="section-body-{{ sev }}">
    <table aria-label="{{ sev | upper }} findings table">
      <caption class="sr-only">{{ sev | upper }} severity findings — {{ sev_findings | length }} result{{ 's' if sev_findings | length != 1 else '' }}</caption>
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">File</th>
          <th scope="col">Line</th>
          <th scope="col">Rule</th>
          <th scope="col">Category</th>
          <th scope="col">Match</th>
          {% if show_confidence %}<th scope="col">Confidence</th>{% endif %}
          {% if obfuscation_items %}<th scope="col">Obfuscation</th>{% endif %}
          <th scope="col">Regulations</th>
          <th scope="col">Scanners</th>
          <th scope="col">Remediation</th>
        </tr>
      </thead>
      <tbody>
        {% for f in sev_findings %}
        <tr>
          <td><code>{{ f.id }}</code></td>
          <td><code>{{ f.file }}</code></td>
          <td>{{ f.line }}</td>
          <td><code>{{ f.rule_id }}</code></td>
          <td><code>{{ f.category }}</code></td>
          {% set _obf = obfuscation_items.get(f.id) if obfuscation_items else none %}
          <td><code>{{ (_obf.raw_match if (_obf and _obf.raw_match) else f.match) }}</code></td>
          {% if show_confidence %}
          <td>
            {% if f.confidence >= 0.85 %}
              <span class="conf-badge conf-high" title="{{ (f.confidence * 100) | int }}% confidence">{{ (f.confidence * 100) | int }}%</span>
            {% elif f.confidence >= 0.65 %}
              <span class="conf-badge conf-med" title="{{ (f.confidence * 100) | int }}% confidence">{{ (f.confidence * 100) | int }}%</span>
            {% else %}
              <span class="conf-badge conf-low" title="{{ (f.confidence * 100) | int }}% confidence">{{ (f.confidence * 100) | int }}%</span>
            {% endif %}
          </td>
          {% endif %}
          {% if obfuscation_items %}
          <td>
            {% set obf = obfuscation_items.get(f.id) %}
            {% if obf %}
              {% if obf.decision == 'approved' %}
                <span class="obf-badge obf-approved" aria-label="Obfuscated to {{ obf.replacement }}">&#10003; Obfuscated</span>
                <code style="display:block;margin-top:.25rem;font-size:.7rem;">{{ obf.replacement }}</code>
              {% elif obf.decision == 'skipped' %}
                <span class="obf-badge obf-skipped">Skipped</span>
                {% if obf.skip_reason %}<span class="obf-reason">{{ obf.skip_reason }}</span>{% endif %}
              {% elif obf.decision == 'manual' %}
                <span class="obf-badge obf-manual">Manual Required</span>
                {% if obf.reason %}<span class="obf-reason">{{ obf.reason }}</span>{% endif %}
              {% elif obf.decision == 'pending' %}
                <span class="obf-badge obf-pending">Pending</span>
              {% endif %}
            {% else %}
              <span aria-label="Not in session">—</span>
            {% endif %}
          </td>
          {% endif %}
          <td>
            {% for reg in f.regulations | sort %}
              <span class="reg-badge {{ reg }}">{{ reg }}</span>
            {% endfor %}
            {% if not f.regulations %}<span aria-label="No regulations">—</span>{% endif %}
          </td>
          <td>{{ f.scanners | join(', ') }}</td>
          <td>
            {% if f.fix_steps %}
            <details>
              <summary>View fix for {{ f.rule_id }}</summary>
              <div class="remediation">
                <strong>{{ f.remediation_description or f.category }}</strong>
                <ol>
                  {% for step in f.fix_steps %}<li>{{ step }}</li>{% endfor %}
                </ol>
                {% if f.references %}
                <div class="refs">
                  {% for ref in f.references %}
                    {% if ref.startswith('http') %}
                      <a href="{{ ref }}" target="_blank" rel="noopener noreferrer">
                        {{ ref }}<span class="sr-only"> (opens in new tab)</span>
                      </a><br>
                    {% else %}<span>{{ ref }}</span><br>{% endif %}
                  {% endfor %}
                </div>
                {% endif %}
              </div>
            </details>
            {% else %}
            <span aria-label="No remediation steps">—</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    </div>
  </section>
  {% endif %}
{% endfor %}

{% endif %}

</main>

<script>
function toggle(btn) {
  const expanded = btn.getAttribute('aria-expanded') === 'true';
  btn.setAttribute('aria-expanded', String(!expanded));
  const body = document.getElementById(btn.getAttribute('aria-controls'));
  if (body) {
    body.style.display = expanded ? 'none' : '';
  }
}
</script>
</body>
</html>
